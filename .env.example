# 环境变量配置示例
# 请根据实际情况修改这些值

# API配置
PORT=8000
OPENROUTER_API_KEY=your_openrouter_api_key_here

# 数据库配置（如果使用外部数据库）
DATABASE_URL=sqlite:///app/database/collection.db

# CORS配置（前端域名）
FRONTEND_URL=https://your-frontend-domain.zeabur.app

# 管理员凭证
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here

# 日志级别
LOG_LEVEL=INFO

# 数据版本配置
DEFAULT_DATA_YEAR=2025
AUTO_SWITCH_ENABLED=false
AUTO_SWITCH_COMPLETENESS=100
