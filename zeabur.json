{
  "name": "xuefeng-volunteer",
  "description": "高考志愿填报系统 - Zeabur部署配置",
  "services": [
    {
      "name": "backend-api",
      "type": "docker",
      "docker": {
        "dockerfile": "backend/Dockerfile",
        "context": "backend"
      },
      "env": {
        "PORT": "8000",
        "PYTHONUNBUFFERED": "1",
        "OPENROUTER_API_KEY": ""
      },
      "ports": [
        {
          "port": 8000,
          "protocol": "HTTP"
        }
      ],
      "healthCheck": {
        "httpPath": "/health",
        "interval": "30s",
        "timeout": "10s",
        "retries": 3
      },
      "resources": {
        "memory": "768MB",
        "cpu": "0.5"
      },
      "volumes": [
        {
          "path": "/app/data"
        },
        {
          "path": "/app/database"
        },
        {
          "path": "/app/logs"
        }
      ]
    },
    {
      "name": "frontend-web",
      "type": "docker",
      "docker": {
        "dockerfile": "frontend.Dockerfile",
        "context": "."
      },
      "ports": [
        {
          "port": 8080,
          "protocol": "HTTP"
        }
      ],
      "resources": {
        "memory": "256MB",
        "cpu": "0.2"
      }
    }
  ]
}