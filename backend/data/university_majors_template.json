{
  "metadata": {
    "table_name": "university_majors",
    "description": "院校-专业关联表（专业级推荐的核心基础设施）",
    "version": "1.0.0",
    "created_at": "2026-04-30T12:00:00.000000",
    "target_records": 84000,
    "current_records": 0,
    "data_source": "阳光高考网 + 各院校招生网",
    "update_frequency": "每年6-7月"
  },
  "schema": {
    "university_major_id": {
      "type": "string",
      "description": "唯一标识（院校ID_专业代码）",
      "example": "1_080901",
      "format": "{university_id}_{major_code}",
      "primary_key": true
    },
    "university_id": {
      "type": "string",
      "description": "院校ID（关联universities表）",
      "example": "1",
      "foreign_key": "universities.id"
    },
    "university_name": {
      "type": "string",
      "description": "院校名称",
      "example": "北京大学"
    },
    "major_code": {
      "type": "string",
      "description": "专业代码（教育部目录）",
      "example": "080901",
      "format": "6位数字"
    },
    "major_name": {
      "type": "string",
      "description": "专业名称",
      "example": "计算机科学与技术"
    },
    "major_category": {
      "type": "string",
      "description": "专业所属类别（工学、理学等）",
      "example": "工学"
    },
    "is_active": {
      "type": "boolean",
      "description": "该专业是否在该校开设",
      "example": true
    },
    "year": {
      "type": "integer",
      "description": "数据年份",
      "example": 2024
    },
    "metadata": {
      "type": "object",
      "description": "元数据",
      "properties": {
        "tuition_fee": {
          "type": "string",
          "description": "学费",
          "example": "5000-7000元/年"
        },
        "duration": {
          "type": "string",
          "description": "学制",
          "example": "4年"
        },
        "subject_requirements": {
          "type": "string",
          "description": "选科要求（新高考）",
          "example": "物理+化学/生物"
        },
        "quota": {
          "type": "integer",
          "description": "招生计划人数",
          "example": 16
        }
      }
    }
  },
  "sample_data": [
    {
      "university_major_id": "1_080901",
      "university_id": "1",
      "university_name": "北京大学",
      "major_code": "080901",
      "major_name": "计算机科学与技术",
      "major_category": "工学",
      "is_active": true,
      "year": 2024,
      "metadata": {
        "tuition_fee": "5000-7000元/年",
        "duration": "4年",
        "subject_requirements": "物理+化学/生物",
        "quota": 16
      }
    },
    {
      "university_major_id": "1_080902",
      "university_id": "1",
      "university_name": "北京大学",
      "major_code": "080902",
      "major_name": "软件工程",
      "major_category": "工学",
      "is_active": true,
      "year": 2024,
      "metadata": {
        "tuition_fee": "5000-7000元/年",
        "duration": "4年",
        "subject_requirements": "物理+化学/生物",
        "quota": 16
      }
    }
  ]
}
